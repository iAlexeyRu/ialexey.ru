---
interface Props {
  youtubeId: string;
}

const { youtubeId } = Astro.props;
---

<div class="stream-banner" id="stream-block" data-youtube-id={youtubeId}>
    <div class="stream-header-row">
        <div class="stream-title-wrap">
            <span class="stream-status-dot" id="stream-status-dot"></span>
            <span class="stream-status-text" id="stream-status-text">Загрузка трансляции...</span>
        </div>
        <button id="toggle-stream-btn" class="toggle-stream-btn" aria-label="Свернуть блок">
            <span class="toggle-text">Свернуть</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="toggle-icon"><path d="m18 15-6-6-6 6"/></svg>
        </button>
    </div>
    <div class="stream-body-collapsible" id="stream-body-collapsible">
        <!-- Responsive Video Embed Container -->
        <div class="stream-embed-container" id="stream-embed-container">
            <!-- Embed will be dynamically injected by JS below -->
            <div class="stream-skeleton" id="stream-skeleton">
                <div class="stream-skeleton-glow"></div>
            </div>
        </div>
    </div>
</div>

<script>
  const streamBlock = document.getElementById('stream-block');
  const statusDot = document.getElementById('stream-status-dot');
  const statusText = document.getElementById('stream-status-text');
  const embedContainer = document.getElementById('stream-embed-container');
  const toggleBtn = document.getElementById('toggle-stream-btn');
  const toggleText = toggleBtn?.querySelector('.toggle-text');
  const youtubeId = streamBlock?.getAttribute('data-youtube-id') || 'e-RHZvID8q8';

  if (streamBlock && embedContainer) {
      // 1. Fetch live status from Decapi.me
      fetch('https://decapi.me/twitch/uptime/ialexeyru')
          .then(res => res.text())
          .then(text => {
              const isLive = !text.toLowerCase().includes('offline');
              if (isLive) {
                  statusDot?.classList.add('live');
                  if (statusText) statusText.textContent = 'LIVE: Трансляция на Twitch';
                  streamBlock.classList.add('live-border');
                  embedContainer.innerHTML = `
                      <iframe
                          src="https://player.twitch.tv/?channel=ialexeyru&parent=ialexey.ru&parent=localhost&parent=127.0.0.1&autoplay=false"
                          style="border: 0; width: 100%; height: 100%;"
                          allowfullscreen="true">
                      </iframe>
                  `;
              } else {
                  statusDot?.classList.add('offline');
                  if (statusText) statusText.textContent = 'Видео';
                  streamBlock.classList.add('offline-border');
                  embedContainer.innerHTML = `
                      <iframe
                          src="https://www.youtube.com/embed/${youtubeId}"
                          style="border: 0; width: 100%; height: 100%;"
                          allowfullscreen="true"
                          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture">
                      </iframe>
                  `;
              }
          })
          .catch(() => {
              // Fallback to YouTube on error
              statusDot?.classList.add('offline');
              if (statusText) statusText.textContent = 'Видео';
              streamBlock.classList.add('offline-border');
              embedContainer.innerHTML = `
                  <iframe
                      src="https://www.youtube.com/embed/${youtubeId}"
                      style="border: 0; width: 100%; height: 100%;"
                      allowfullscreen="true"
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture">
                  </iframe>
              `;
          });

      // 2. Collapse Toggle
      if (toggleBtn && toggleText) {
          toggleBtn.addEventListener('click', () => {
              const isCollapsed = streamBlock.classList.toggle('stream-banner--collapsed');
              toggleText.textContent = isCollapsed ? 'Развернуть' : 'Свернуть';
          });
      }
  }
</script>

<style>
  .stream-banner {
      background: linear-gradient(135deg, rgba(25, 20, 36, 0.6) 0%, rgba(13, 17, 26, 0.8) 100%);
      border: 1px solid rgba(145, 70, 255, 0.2);
      border-radius: 16px;
      padding: 0.9rem 1.15rem;
      position: relative;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(145, 70, 255, 0.05);
      transition: all 0.3s ease;
  }

  .stream-header-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 0.75rem;
      transition: margin 0.3s ease;
      flex-wrap: wrap;
      gap: 0.5rem;
  }

  .stream-banner--collapsed .stream-header-row {
      margin-bottom: 0;
  }

  .stream-title-wrap {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
  }

  .stream-status-dot {
      width: 8px;
      height: 8px;
      background-color: #6c7482;
      border-radius: 50%;
      transition: all 0.3s ease;
  }

  .stream-status-dot.live {
      background-color: #F04465; /* Match --accent */
      box-shadow: 0 0 10px #F04465;
      animation: streamPulse 1.8s infinite;
  }

  @keyframes streamPulse {
      0% { transform: scale(0.9); opacity: 0.6; }
      50% { transform: scale(1.2); opacity: 1; }
      100% { transform: scale(0.9); opacity: 0.6; }
  }

  .stream-status-dot.offline {
      background-color: #ff0055;
      box-shadow: 0 0 8px rgba(255, 0, 85, 0.4);
  }

  .stream-status-text {
      font-family: var(--font-heading);
      font-size: 0.82rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--text-header);
  }

  .toggle-stream-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: transparent;
      border: none;
      color: #6c7482;
      font-family: var(--font-mono);
      font-size: 0.72rem;
      cursor: pointer;
      padding: 4px 8px;
      border-radius: 4px;
      transition: all 0.2s ease;
  }

  .toggle-stream-btn:hover {
      color: var(--text-header);
      background-color: var(--border-soft);
  }

  .toggle-icon {
      width: 14px;
      height: 14px;
      transition: transform 0.3s ease;
  }

  .stream-banner--collapsed .toggle-icon {
      transform: rotate(180deg);
  }

  .stream-body-collapsible {
      max-height: 800px;
      overflow: hidden;
      transition: max-height 0.4s cubic-bezier(0, 1, 0, 1);
  }

  .stream-banner--collapsed .stream-body-collapsible {
      max-height: 0;
  }

  .stream-embed-container {
      aspect-ratio: 16 / 9;
      width: 100%;
      border-radius: 10px;
      overflow: hidden;
      border: 1px solid rgba(145, 70, 255, 0.25);
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.5);
  }

  .stream-banner.live-border {
      border-color: rgba(145, 70, 255, 0.3);
  }

  .stream-banner.offline-border {
      border-color: rgba(255, 0, 85, 0.2);
  }

  .stream-banner::before {
      content: "";
      position: absolute;
      top: -50%;
      right: -20%;
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(145, 70, 255, 0.15) 0%, transparent 70%);
      pointer-events: none;
  }

  .stream-skeleton {
      width: 100%;
      height: 100%;
      background-color: #161b22;
      position: relative;
      overflow: hidden;
  }

  .stream-skeleton-glow {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.05), transparent);
      animation: skeletonLoading 1.5s infinite;
  }

  @keyframes skeletonLoading {
      0% { transform: translateX(-100%); }
      100% { transform: translateX(100%); }
  }
</style>
