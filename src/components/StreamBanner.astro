---
interface Props {
  youtubeId: string;
}

const { youtubeId } = Astro.props;
const youtubeThumbnailUrl = `https://img.youtube.com/vi/${youtubeId}/maxresdefault.jpg`;
---

<div class="stream-banner" id="stream-block" data-youtube-id={youtubeId}>
    <div class="stream-header-row">
        <div class="stream-title-wrap">
            <span class="stream-status-dot offline" id="stream-status-dot"></span>
            <span class="stream-status-text" id="stream-status-text">Видео</span>
        </div>
        <button id="toggle-stream-btn" class="toggle-stream-btn" aria-label="Свернуть блок">
            <span class="toggle-text">Свернуть</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="toggle-icon"><path d="m18 15-6-6-6 6"/></svg>
        </button>
    </div>
    <div class="stream-body-collapsible" id="stream-body-collapsible">
        <div class="stream-embed-container" id="stream-embed-container">
            <div class="stream-lazy-cover youtube-cover" id="stream-play-trigger">
                <img
                    src={youtubeThumbnailUrl}
                    alt="Запустить видео"
                    class="stream-cover-img"
                    width="640"
                    height="360"
                    loading="eager"
                    decoding="async"
                    fetchpriority="high"
                />
                <div class="cover-overlay"></div>
                <div class="play-btn-circle yt-red-btn">
                    <svg viewBox="0 0 24 24" fill="currentColor" class="play-icon-svg"><path d="M8 5v14l11-7z"/></svg>
                </div>
                <span class="cover-label">Запустить видео</span>
            </div>
        </div>
    </div>
</div>

<script>
  const streamBlock = document.getElementById('stream-block');
  const statusDot = document.getElementById('stream-status-dot');
  const statusText = document.getElementById('stream-status-text');
  const embedContainer = document.getElementById('stream-embed-container');
  const toggleBtn = document.getElementById('toggle-stream-btn');
  const toggleText = toggleBtn?.querySelector('.toggle-text');
  const youtubeId = streamBlock?.getAttribute('data-youtube-id') || 'e-RHZvID8q8';

  function buildYoutubeCover(videoId) {
    return `
      <div class="stream-lazy-cover youtube-cover" id="stream-play-trigger">
          <img
              src="https://img.youtube.com/vi/${videoId}/maxresdefault.jpg"
              alt="Запустить видео"
              class="stream-cover-img"
              width="640"
              height="360"
              loading="lazy"
              decoding="async"
          />
          <div class="cover-overlay"></div>
          <div class="play-btn-circle yt-red-btn">
              <svg viewBox="0 0 24 24" fill="currentColor" class="play-icon-svg"><path d="M8 5v14l11-7z"/></svg>
          </div>
          <span class="cover-label">Запустить видео</span>
      </div>
    `;
  }

  function attachYoutubeClick(videoId) {
    document.getElementById('stream-play-trigger')?.addEventListener('click', () => {
      if (!embedContainer) return;
      embedContainer.innerHTML = `
        <iframe
            src="https://www.youtube.com/embed/${videoId}?autoplay=1"
            style="border: 0; width: 100%; height: 100%;"
            allowfullscreen="true"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture">
        </iframe>
      `;
    });
  }

  function showYoutubeOffline(videoId) {
    if (!embedContainer) return;
    statusDot?.classList.add('offline');
    if (statusText) statusText.textContent = 'Видео';
    streamBlock?.classList.add('offline-border');
    embedContainer.innerHTML = buildYoutubeCover(videoId);
    attachYoutubeClick(videoId);
  }

  function checkLiveStatus() {
      if (!streamBlock || !embedContainer) return;
      fetch('https://decapi.me/twitch/uptime/ialexeyru')
          .then(res => res.text())
          .then(text => {
              const isLive = !text.toLowerCase().includes('offline');
              if (isLive) {
                  statusDot?.classList.remove('offline');
                  statusDot?.classList.add('live');
                  if (statusText) statusText.textContent = 'LIVE: Трансляция на Twitch';
                  streamBlock.classList.remove('offline-border');
                  streamBlock.classList.add('live-border');
                  
                  embedContainer.innerHTML = `
                      <div class="stream-lazy-cover twitch-cover" id="stream-play-trigger">
                          <div class="play-btn-circle">
                              <svg viewBox="0 0 24 24" fill="currentColor" class="play-icon-svg"><path d="M8 5v14l11-7z"/></svg>
                          </div>
                          <span class="cover-label">Смотреть на Twitch</span>
                      </div>
                  `;
                  
                  document.getElementById('stream-play-trigger')?.addEventListener('click', () => {
                      if (!embedContainer) return;
                      embedContainer.innerHTML = `
                          <iframe
                              src="https://player.twitch.tv/?channel=ialexeyru&parent=ialexey.ru&parent=localhost&parent=127.0.0.1&autoplay=true"
                              style="border: 0; width: 100%; height: 100%;"
                              allowfullscreen="true">
                          </iframe>
                      `;
                  });
              } else {
                  statusDot?.classList.add('offline');
                  if (statusText) statusText.textContent = 'Видео';
                  streamBlock.classList.add('offline-border');
              }
          })
          .catch(() => {});
  }

  if (streamBlock && embedContainer) {
      attachYoutubeClick(youtubeId);

      if (toggleBtn && toggleText) {
          toggleBtn.addEventListener('click', () => {
              const isCollapsed = streamBlock.classList.toggle('stream-banner--collapsed');
              toggleText.textContent = isCollapsed ? 'Развернуть' : 'Свернуть';
          });
      }

      window.addEventListener('load', () => {
          window.setTimeout(checkLiveStatus, 1200);
      }, { once: true });
  }
</script>

<style>
  .stream-banner {
      background: linear-gradient(135deg, rgba(25, 20, 36, 0.6) 0%, rgba(13, 17, 26, 0.8) 100%);
      border: 1px solid rgba(145, 70, 255, 0.2);
      border-radius: 16px;
      padding: 0.9rem 1.15rem;
      position: relative;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(145, 70, 255, 0.05);
      transition: all 0.3s ease;
  }

  .stream-header-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 0.75rem;
      transition: margin 0.3s ease;
      flex-wrap: wrap;
      gap: 0.5rem;
  }

  .stream-banner--collapsed .stream-header-row {
      margin-bottom: 0;
  }

  .stream-title-wrap {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
  }

  .stream-status-dot {
      width: 8px;
      height: 8px;
      background-color: #6c7482;
      border-radius: 50%;
      transition: all 0.3s ease;
  }

  .stream-status-dot.live {
      background-color: #F04465; /* Match --accent */
      box-shadow: 0 0 10px #F04465;
      animation: streamPulse 1.8s infinite;
  }

  @keyframes streamPulse {
      0% { transform: scale(0.9); opacity: 0.6; }
      50% { transform: scale(1.2); opacity: 1; }
      100% { transform: scale(0.9); opacity: 0.6; }
  }

  .stream-status-dot.offline {
      background-color: #ff0055;
      box-shadow: 0 0 8px rgba(255, 0, 85, 0.4);
  }

  .stream-status-text {
      font-family: var(--font-heading);
      font-size: 0.82rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--text-header);
  }

  .toggle-stream-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: transparent;
      border: none;
      color: #6c7482;
      font-family: var(--font-mono);
      font-size: 0.72rem;
      cursor: pointer;
      padding: 4px 8px;
      border-radius: 4px;
      transition: all 0.2s ease;
  }

  .toggle-stream-btn:hover {
      color: var(--text-header);
      background-color: var(--border-soft);
  }

  .toggle-icon {
      width: 14px;
      height: 14px;
      transition: transform 0.3s ease;
  }

  .stream-banner--collapsed .toggle-icon {
      transform: rotate(180deg);
  }

  .stream-body-collapsible {
      max-height: 800px;
      overflow: hidden;
      transition: max-height 0.4s cubic-bezier(0, 1, 0, 1);
  }

  .stream-banner--collapsed .stream-body-collapsible {
      max-height: 0;
  }

  .stream-embed-container {
      aspect-ratio: 16 / 9;
      width: 100%;
      border-radius: 10px;
      overflow: hidden;
      border: 1px solid rgba(145, 70, 255, 0.25);
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.5);
  }

  .stream-banner.live-border {
      border-color: rgba(145, 70, 255, 0.3);
  }

  .stream-banner.offline-border {
      border-color: rgba(255, 0, 85, 0.2);
  }

  .stream-banner::before {
      content: "";
      position: absolute;
      top: -50%;
      right: -20%;
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(145, 70, 255, 0.15) 0%, transparent 70%);
      pointer-events: none;
  }

  .stream-skeleton {
      width: 100%;
      height: 100%;
      background-color: #161b22;
      position: relative;
      overflow: hidden;
  }

  .stream-skeleton-glow {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.05), transparent);
      animation: skeletonLoading 1.5s infinite;
  }

  @keyframes skeletonLoading {
      0% { transform: translateX(-100%); }
      100% { transform: translateX(100%); }
  }

  /* Lazy Lite Embed Covers */
  .stream-lazy-cover {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      cursor: pointer;
      user-select: none;
  }

  .twitch-cover {
      background: linear-gradient(135deg, #6441a5 0%, #2b1b54 100%);
  }

  .stream-cover-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
  }

  .cover-overlay {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.4);
      z-index: 1;
  }

  .play-btn-circle {
      width: 68px;
      height: 68px;
      background: rgba(145, 70, 255, 0.85); /* Twitch purple */
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 2px solid #ffffff;
      z-index: 2;
      transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.4);
  }

  .yt-red-btn {
      background: rgba(229, 9, 20, 0.9) !important; /* YouTube Red */
  }

  .play-icon-svg {
      width: 28px;
      height: 28px;
      margin-left: 4px;
      color: #ffffff;
  }

  .cover-label {
      position: absolute;
      bottom: 12px;
      font-family: var(--font-heading);
      font-size: 0.72rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: #ffffff;
      opacity: 0.85;
      z-index: 2;
      transition: opacity 0.25s ease;
  }

  .stream-lazy-cover:hover .play-btn-circle {
      transform: scale(1.1);
      box-shadow: 0 0 25px rgba(255, 255, 255, 0.3);
  }

  .stream-lazy-cover:hover .cover-label {
      opacity: 1;
  }
</style>
