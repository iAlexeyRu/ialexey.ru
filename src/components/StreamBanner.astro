---
interface Props {
  youtubeId: string;
}

const { youtubeId } = Astro.props;
const youtubeThumbnailUrl = `/stream-cover-${youtubeId}.webp`;
---

<div class="stream-banner" id="stream-block" data-youtube-id={youtubeId}>
    <div class="stream-embed-container" id="stream-embed-container">
        <div class="stream-lazy-cover youtube-cover" id="stream-play-trigger">
            <img
                src={youtubeThumbnailUrl}
                alt="Запустить видео"
                class="stream-cover-img"
                width="640"
                height="360"
                loading="eager"
                decoding="async"
                fetchpriority="high"
            />
            <div class="cover-overlay"></div>
            <div class="play-btn-circle yt-red-btn">
                <svg viewBox="0 0 24 24" fill="currentColor" class="play-icon-svg"><path d="M8 5v14l11-7z"/></svg>
            </div>
            <span class="cover-label">Запустить видео</span>
        </div>
    </div>
</div>

<script>
  const streamBlock = document.getElementById('stream-block');
  const embedContainer = document.getElementById('stream-embed-container');
  const youtubeId = streamBlock?.getAttribute('data-youtube-id') || 'e-RHZvID8q8';

  function buildYoutubeCover(videoId) {
    return `
      <div class="stream-lazy-cover youtube-cover" id="stream-play-trigger">
          <img
              src="/stream-cover-${videoId}.webp"
              alt="Запустить видео"
              class="stream-cover-img"
              width="640"
              height="360"
              loading="lazy"
              decoding="async"
          />
          <div class="cover-overlay"></div>
          <div class="play-btn-circle yt-red-btn">
              <svg viewBox="0 0 24 24" fill="currentColor" class="play-icon-svg"><path d="M8 5v14l11-7z"/></svg>
          </div>
          <span class="cover-label">Запустить видео</span>
      </div>
    `;
  }

  function attachYoutubeClick(videoId) {
    document.getElementById('stream-play-trigger')?.addEventListener('click', () => {
      if (!embedContainer) return;
      embedContainer.innerHTML = `
        <iframe
            src="https://www.youtube.com/embed/${videoId}?autoplay=1"
            style="border: 0; width: 100%; height: 100%;"
            allowfullscreen="true"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture">
        </iframe>
      `;
    });
  }

  function checkLiveStatus() {
      if (!streamBlock || !embedContainer) return;
      fetch('https://decapi.me/twitch/uptime/ialexeyru')
          .then(res => res.text())
          .then(text => {
              const isLive = !text.toLowerCase().includes('offline');
              if (isLive) {
                  streamBlock.classList.remove('offline-border');
                  streamBlock.classList.add('live-border');
                  
                  embedContainer.innerHTML = `
                      <div class="stream-lazy-cover twitch-cover" id="stream-play-trigger">
                          <div class="play-btn-circle">
                              <svg viewBox="0 0 24 24" fill="currentColor" class="play-icon-svg"><path d="M8 5v14l11-7z"/></svg>
                          </div>
                          <span class="cover-label">Смотреть на Twitch</span>
                      </div>
                  `;
                  
                  document.getElementById('stream-play-trigger')?.addEventListener('click', () => {
                      if (!embedContainer) return;
                      embedContainer.innerHTML = `
                          <iframe
                              src="https://player.twitch.tv/?channel=ialexeyru&parent=ialexey.ru&parent=localhost&parent=127.0.0.1&autoplay=true"
                              style="border: 0; width: 100%; height: 100%;"
                              allowfullscreen="true">
                          </iframe>
                      `;
                  });
              } else {
                  streamBlock.classList.add('offline-border');
              }
          })
          .catch(() => {});
  }

  if (streamBlock && embedContainer) {
      attachYoutubeClick(youtubeId);

      window.addEventListener('load', () => {
          window.setTimeout(checkLiveStatus, 1200);
      }, { once: true });
  }
</script>

<style>
  .stream-banner {
      position: relative;
      aspect-ratio: 16 / 9;
      width: 100%;
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid var(--border-soft);
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .stream-banner:hover {
      border-color: var(--border-hover);
      box-shadow: 0 8px 24px var(--accent-glow);
  }

  .stream-embed-container {
      width: 100%;
      height: 100%;
      position: relative;
  }

  .stream-banner.live-border {
      border-color: #9146ff;
      box-shadow: 0 0 15px rgba(145, 70, 255, 0.3);
  }

  .stream-banner.offline-border {
      border-color: var(--border-soft);
  }

  /* Lazy Lite Embed Covers */
  .stream-lazy-cover {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      cursor: pointer;
      user-select: none;
  }

  .twitch-cover {
      background: linear-gradient(135deg, #6441a5 0%, #2b1b54 100%);
  }

  .stream-cover-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
  }

  .cover-overlay {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.35);
      z-index: 1;
      transition: background 0.25s ease;
  }

  .stream-lazy-cover:hover .cover-overlay {
      background: rgba(0, 0, 0, 0.2);
  }

  .play-btn-circle {
      width: 54px;
      height: 54px;
      background: rgba(145, 70, 255, 0.9); /* Twitch purple */
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 2px solid #ffffff;
      z-index: 2;
      transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.4);
  }

  .yt-red-btn {
      background: rgba(229, 9, 20, 0.95) !important; /* YouTube Red */
  }

  .play-icon-svg {
      width: 22px;
      height: 22px;
      margin-left: 3px;
      color: #ffffff;
  }

  .cover-label {
      position: absolute;
      bottom: 12px;
      font-family: var(--font-heading);
      font-size: 0.65rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: #ffffff;
      opacity: 0.85;
      z-index: 2;
      transition: opacity 0.25s ease;
  }

  .stream-lazy-cover:hover .play-btn-circle {
      transform: scale(1.1);
      box-shadow: 0 0 20px rgba(255, 255, 255, 0.4);
  }

  .stream-lazy-cover:hover .cover-label {
      opacity: 1;
  }
</style>
