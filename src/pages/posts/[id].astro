---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../../layouts/Layout.astro';
import {
  getFirstSentence,
  truncateText,
  getSmartBadge,
  formatDate,
  sanitizeHtml
} from '../../utils/helpers';

// getStaticPaths is required in Astro static mode for dynamic routes
export async function getStaticPaths() {
  const fs = await import('node:fs');
  const path = await import('node:path');
  
  const dataDir = process.env.DATA_DIR || '/home/deploy/ialexey-feed/data';
  const prodFeedJsonPath = path.join(dataDir, 'feed.json');
  const localFeedJsonPath = path.resolve('src/data/feed.json');

  let parsedData = null;

  if (fs.existsSync(prodFeedJsonPath)) {
    try {
      parsedData = JSON.parse(fs.readFileSync(prodFeedJsonPath, 'utf-8'));
    } catch (e) {
      console.error(e);
    }
  }

  if (!parsedData && fs.existsSync(localFeedJsonPath)) {
    try {
      parsedData = JSON.parse(fs.readFileSync(localFeedJsonPath, 'utf-8'));
    } catch (e) {
      console.error(e);
    }
  }

  let feedItems = [];
  if (parsedData) {
    if (Array.isArray(parsedData)) {
      feedItems = parsedData;
    } else if (parsedData.items && Array.isArray(parsedData.items)) {
      feedItems = parsedData.items;
    }
  }

  // Sort items by date descending to find the newest posts
  const sortedItems = [...feedItems].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

  return sortedItems.map((item: any) => {
    const id = item.message_id || item.id.split(':').pop();
    
    // Select latest 3 posts excluding the current one for related grid
    const latestPosts = sortedItems
      .filter((x: any) => {
        const xId = x.message_id || x.id.split(':').pop();
        return String(xId) !== String(id);
      })
      .slice(0, 3)
      .map((x: any) => ({
        id: x.message_id || x.id.split(':').pop(),
        title: getFirstSentence(x.text || ""),
        date: x.date,
        image: x.image
      }));

    return {
      params: { id: String(id) },
      props: { item, latestPosts },
    };
  });
}

interface Props {
  item: any;
  latestPosts: Array<{
    id: string | number;
    title: string;
    date: string;
    image: string | null;
  }>;
}

const { id } = Astro.params;
const { item, latestPosts } = Astro.props as Props;

const channelUsername = "iAlexeyRu";
const siteAuthor = "Алексей Гетманец";

// Scoped split post helper is kept locally since it performs the HTML tag index traversal


// Helper to split post content into first sentence (title) and the remaining body text/HTML
function splitPostContent(text: string, html: string) {
  if (!text) return { title: "", titleHtml: "", bodyHtml: "" };
  
  const firstSentence = getFirstSentence(text);
  
  // Consume HTML to find exact index corresponding to firstSentence length
  const targetLen = firstSentence.length;
  let textCharCount = 0;
  let htmlIdx = 0;
  let insideTag = false;
  const rawHtml = html || text;
  
  while (htmlIdx < rawHtml.length && textCharCount < targetLen) {
    const char = rawHtml[htmlIdx];
    if (char === '<') {
      insideTag = true;
      htmlIdx++;
    } else if (char === '>') {
      insideTag = false;
      htmlIdx++;
    } else if (insideTag) {
      htmlIdx++;
    } else {
      if (char === '&') {
        const semiIdx = rawHtml.indexOf(';', htmlIdx);
        if (semiIdx !== -1 && semiIdx - htmlIdx < 10) {
          htmlIdx = semiIdx + 1;
          textCharCount++;
          continue;
        }
      }
      textCharCount++;
      htmlIdx++;
    }
  }
  
  let titleHtml = rawHtml.slice(0, htmlIdx).trim();
  let bodyHtml = rawHtml.slice(htmlIdx).trim();
  
  // Strip trailing breaks from title and leading breaks from body
  titleHtml = titleHtml.replace(/<br\s*\/?>$/, '').trim();
  while (bodyHtml.startsWith('<br>') || bodyHtml.startsWith('<br/>') || bodyHtml.startsWith('<br />')) {
    bodyHtml = bodyHtml.replace(/^<br\s*\/?>/, '').trim();
  }
  
  // Clean plain text version of the title for page tags
  const plainTitle = titleHtml
    .replace(/<[^>]+>/g, '')
    .replace(/&amp;/g, '&')
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'");
    
  return {
    title: plainTitle || firstSentence,
    titleHtml: titleHtml || firstSentence,
    bodyHtml: bodyHtml
  };
}

const { title: postTitle, titleHtml: postTitleHtml, bodyHtml: postBodyHtml } = splitPostContent(item.text || "", item.html || "");

const pageMetaTitle = postTitle || `Пост Telegram ${id}`;
const postDescription = truncateText(postBodyHtml.replace(/<[^>]+>/g, '') || item.text || "", 220) || "Сливы и новости ИИ от Алексея Гетманца: короткая Telegram-лента, RSS и статические страницы постов.";

const localUrl = `https://ialexey.ru/posts/${id}`;
const telegramUrl = item.url || `https://t.me/${channelUsername}/${id}`;



const formattedDate = formatDate(item.date);
const badge = getSmartBadge(item.text);

// Schema.org Article dynamic markup
const schemaObject = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": postTitle,
  "description": postDescription,
  "url": localUrl,
  "datePublished": item.date,
  "dateModified": item.date,
  "inLanguage": "ru-RU",
  "author": {
    "@type": "Person",
    "name": siteAuthor,
    "url": "https://ialexey.ru/"
  },
  "publisher": {
    "@type": "Person",
    "name": siteAuthor,
    "url": "https://ialexey.ru/"
  },
  "mainEntityOfPage": localUrl,
  "isBasedOn": telegramUrl
};

const schema = JSON.stringify(schemaObject);
---
<Layout title={`${pageMetaTitle} | ${siteAuthor}`} description={postDescription} schema={schema} canonicalUrl={localUrl}>
  <main class="post-main">
      
      <!-- Scoped back button -->
      <a class="back-link" href="/">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="back-arrow"><path d="m15 18-6-6 6-6"/></svg>
          <span>На главную</span>
      </a>

      <article class="post-article">
          <div class="meta-row">
              <span class={`badge ${badge.class}`}>{badge.label}</span>
              <div class="meta-right">
                  <a href={telegramUrl} target="_blank" rel="noopener" class="tg-source">Telegram / @{channelUsername}</a>
                  <span class="meta-dot">•</span>
                  <time datetime={item.date}>{formattedDate} MSK</time>
              </div>
          </div>
          
          <h1 class="article-title" set:html={sanitizeHtml(postTitleHtml)}></h1>
          
          {item.image && (
              <div class="article-image-wrap">
                  <img 
                      src={`/${item.image}`} 
                      class="article-image" 
                      alt={postTitle}
                  />
              </div>
          )}
          
          <div class="article-body" set:html={sanitizeHtml(postBodyHtml || item.html || item.text)}></div>

          <!-- Divider -->
          <div class="post-divider"></div>

          <!-- Share Bar with Likes -->
          <div class="share-bar">
              <div class="likes-container">
                  <button class="like-btn" id="like-btn" data-post-id={id} aria-label="Поставить лайк">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="like-btn-icon">
                          <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
                      </svg>
                      <span id="like-count">0</span>
                  </button>
              </div>
              <div class="share-buttons-wrap">
                  <span class="share-title">Поделиться:</span>
                  <div class="share-buttons">
                      <a href={`https://t.me/share/url?url=${encodeURIComponent(localUrl)}&text=${encodeURIComponent(postTitle)}`} target="_blank" rel="noopener noreferrer" class="share-btn share-btn--telegram" aria-label="Поделиться в Telegram">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="share-btn-icon tg-icon-stroke"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
                          <span>Telegram</span>
                      </a>
                      <a href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(localUrl)}&text=${encodeURIComponent(postTitle)}`} target="_blank" rel="noopener noreferrer" class="share-btn share-btn--twitter" aria-label="Поделиться в X">
                          <svg viewBox="0 0 24 24" fill="currentColor" class="share-btn-icon"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                          <span>X (Twitter)</span>
                      </a>
                      <button class="share-btn share-btn--copy" id="copy-link-btn" data-url={localUrl} aria-label="Скопировать ссылку">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="share-btn-icon"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                          <span id="copy-btn-text">Ссылка</span>
                      </button>
                  </div>
              </div>
          </div>
      </article>

      <!-- Comments Section (Giscus) -->
      <div class="comments-section">
          <div id="giscus-container" class="giscus-container">
              <!-- Dynamic Giscus iframe will load here -->
          </div>
      </div>

      <!-- Related Posts Section -->
      {latestPosts && latestPosts.length > 0 && (
          <div class="related-posts">
              <h2 class="related-title">Читайте также</h2>
              <div class="related-grid">
                  {latestPosts.map((post) => {
                      const postUrl = `/posts/${post.id}/`;
                      const smartBadge = getSmartBadge(post.title);
                      return (
                          <a href={postUrl} class="related-card">
                              <div class="related-card-img-wrap">
                                  {post.image ? (
                                      <img src={`/${post.image}`} alt="Related post" class="related-card-img" loading="lazy" />
                                  ) : (
                                      <div class="related-card-placeholder">
                                          <span>{smartBadge.label}</span>
                                      </div>
                                  )}
                              </div>
                              <div class="related-card-content">
                                  <h3 class="related-card-title">{truncateText(post.title, 55)}</h3>
                                  <span class="related-card-date">{formatDate(post.date)}</span>
                              </div>
                          </a>
                      );
                  })}
              </div>
          </div>
      )}
  </main>

  <!-- Lightbox Modal -->
  <div id="lightbox-modal" class="lightbox-modal">
      <span class="lightbox-close">&times;</span>
      <img class="lightbox-content" id="lightbox-img" alt="Увеличенное изображение" />
  </div>
</Layout>

<style>
  .post-main {
      max-width: 800px;
      margin: 1rem auto 4rem;
  }

  /* Elegant modern back link */
  .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-family: var(--font-mono);
      font-size: 0.85rem;
      color: var(--text-main);
      margin-bottom: 2rem;
      transition: color 0.2s, transform 0.2s;
  }

  .back-arrow {
      width: 16px;
      height: 16px;
      transition: transform 0.2s;
  }

  .back-link:hover {
      color: var(--text-header);
      transform: translateX(-4px);
  }

  .post-article {
      background-color: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 2rem;
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
  }

  .meta-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.25rem;
      flex-wrap: wrap;
      gap: 1rem;
  }

  .meta-right {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--text-muted);
  }

  .tg-source {
      color: var(--text-muted);
      border-bottom: 1px dashed var(--border-dashed);
  }

  .tg-source:hover {
      color: var(--accent);
      border-bottom-color: var(--accent);
  }

  .meta-dot {
      color: var(--meta-dot);
  }

  .article-title {
      font-size: 1.75rem;
      line-height: 1.3;
      color: var(--text-header);
      margin: 0 0 1.5rem;
      letter-spacing: -0.5px;
  }

  .article-image-wrap {
      margin: 0 auto 2rem auto;
      max-width: 560px;
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid var(--border);
      background-color: transparent;
  }

  .article-image {
      width: 100%;
      height: auto;
      display: block;
  }

  .article-body {
      font-size: 1.1rem;
      line-height: 1.7;
      color: var(--text-main);
  }

  .article-body :global(a) {
      color: var(--accent);
      border-bottom: 1px solid var(--accent-glow);
  }

  .article-body :global(a:hover) {
      border-bottom-color: var(--accent);
  }

  @media (max-width: 768px) {
      .post-article {
          padding: 1.25rem;
          border-radius: 12px;
          box-shadow: 0 4px 15px rgba(0, 0, 0, 0.04);
      }
      .article-title {
          font-size: 1.35rem;
          margin-bottom: 1.25rem;
      }
      .meta-row {
          flex-direction: column;
          align-items: flex-start;
          gap: 0.75rem;
      }
      .meta-right {
          width: 100%;
          justify-content: flex-start;
      }
  }

  /* Divider */
  .post-divider {
      height: 1px;
      background-color: var(--border-soft);
      margin: 2.5rem 0 1.5rem;
  }

  /* Share Bar */
  .share-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
  }

  .share-title {
      font-family: var(--font-heading);
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--text-header);
  }

  .share-buttons {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
  }

  .share-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 1rem;
      border-radius: 6px;
      font-family: var(--font-mono);
      font-size: 0.78rem;
      font-weight: bold;
      cursor: pointer;
      border: 1px solid var(--border);
      background-color: rgba(255, 255, 255, 0.02);
      color: var(--text-main);
      transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .share-btn-icon {
      width: 14px;
      height: 14px;
  }

  .share-btn--telegram:hover {
      border-color: #24A1DE;
      color: #24A1DE;
      background-color: rgba(36, 161, 222, 0.05);
  }

  .share-btn--twitter:hover {
      border-color: var(--text-header);
      color: var(--text-header);
      background-color: rgba(255, 255, 255, 0.05);
  }

  .share-btn--copy:hover {
      border-color: var(--accent);
      color: var(--accent);
      background-color: var(--accent-glow);
  }

  .share-btn--copy.copied {
      border-color: #3fb950;
      color: #3fb950;
      background-color: rgba(63, 185, 80, 0.05);
  }

  /* Related Posts Section */
  .related-posts {
      margin-top: 3.5rem;
  }

  .related-title {
      font-size: 1.15rem;
      margin-bottom: 1.5rem;
      font-family: var(--font-heading);
      font-weight: 700;
      color: var(--text-header);
      border-left: 2px solid var(--accent);
      padding-left: 0.6rem;
  }

  .related-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1.5rem;
  }

  .related-card {
      background-color: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .related-card:hover {
      border-color: var(--border-hover);
      box-shadow: 0 8px 24px var(--accent-glow);
      transform: translateY(-3px);
  }

  .related-card-img-wrap {
      width: 100%;
      aspect-ratio: 16 / 9;
      background-color: #000;
      overflow: hidden;
      border-bottom: 1px solid var(--border);
  }

  .related-card-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
  }

  .related-card:hover .related-card-img {
      transform: scale(1.05);
  }

  .related-card-placeholder {
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, var(--card-bg) 0%, var(--bg-color) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-mono);
      font-size: 0.65rem;
      font-weight: bold;
      text-transform: uppercase;
      color: var(--text-muted);
  }

  .related-card-content {
      padding: 1rem;
      display: flex;
      flex-direction: column;
      flex-grow: 1;
  }

  .related-card-title {
      font-size: 0.88rem;
      line-height: 1.4;
      font-weight: 600;
      color: var(--text-header);
      margin: 0 0 0.5rem;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      flex-grow: 1;
      transition: color 0.2s;
  }

  .related-card:hover .related-card-title {
      color: var(--accent);
  }

  .related-card-date {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      color: var(--text-muted);
      margin-top: 0.25rem;
  }

  /* Lightbox Modal */
  .lightbox-modal {
      display: none;
      position: fixed;
      z-index: 1000;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.9);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      align-items: center;
      justify-content: center;
  }

  .lightbox-content {
      max-width: 90%;
      max-height: 85%;
      object-fit: contain;
      border-radius: 8px;
      border: 1px solid var(--border);
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.8);
      animation: zoomIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  @keyframes zoomIn {
      from { transform: scale(0.9); opacity: 0; }
      to { transform: scale(1); opacity: 1; }
  }

  .lightbox-close {
      position: absolute;
      top: 20px;
      right: 30px;
      color: #fff;
      font-size: 40px;
      font-weight: bold;
      cursor: pointer;
      transition: 0.2s;
      user-select: none;
  }

  .lightbox-close:hover {
      color: var(--accent);
      transform: scale(1.1);
  }

    @media (max-width: 600px) {
        .share-bar {
            flex-direction: column;
            align-items: flex-start;
            gap: 1.25rem;
        }
        .share-buttons-wrap {
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 0.5rem;
        }
        .share-buttons {
            width: 100%;
            justify-content: flex-start;
        }
    }

    /* Comments Section */
    .comments-section {
        margin-top: 2rem;
        background-color: transparent;
        border: none;
        padding: 0;
    }

    .comments-title {
        font-size: 1.15rem;
        margin-bottom: 2rem;
        font-family: var(--font-heading);
        font-weight: 700;
        color: var(--text-header);
        border-left: 2px solid var(--accent);
        padding-left: 0.6rem;
    }

    .giscus-container {
        width: 100%;
        min-height: 250px;
    }

    /* Likes Container & Button */
    .likes-container {
        display: flex;
        align-items: center;
    }

    .like-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.5rem 1.1rem;
        border-radius: 6px;
        font-family: var(--font-mono);
        font-size: 0.85rem;
        font-weight: bold;
        cursor: pointer;
        border: 1px solid var(--border);
        background-color: rgba(255, 255, 255, 0.02);
        color: var(--text-main);
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .like-btn-icon {
        width: 16px;
        height: 16px;
        transition: transform 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .like-btn:hover {
        border-color: var(--accent);
        color: var(--accent);
        background-color: var(--accent-glow);
    }

    .like-btn:hover .like-btn-icon {
        transform: scale(1.15);
    }

    .like-btn.liked {
        border-color: var(--accent);
        color: var(--accent);
        background-color: var(--accent-glow);
    }

    .like-btn.liked .like-btn-icon {
        fill: var(--accent);
        stroke: var(--accent);
        animation: heartbeat 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    @keyframes heartbeat {
        0% { transform: scale(1); }
        35% { transform: scale(1.3); }
        70% { transform: scale(0.9); }
        100% { transform: scale(1); }
    }

    .share-buttons-wrap {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
</style>

<script>
  // Share Copy Link Logic
  const copyBtn = document.getElementById('copy-link-btn');
  const copyText = document.getElementById('copy-btn-text');
  if (copyBtn && copyText) {
      copyBtn.addEventListener('click', () => {
          const url = copyBtn.getAttribute('data-url') || window.location.href;
          navigator.clipboard.writeText(url).then(() => {
              copyText.textContent = 'Скопировано!';
              copyBtn.classList.add('copied');
              setTimeout(() => {
                  copyText.textContent = 'Ссылка';
                  copyBtn.classList.remove('copied');
              }, 2000);
          }).catch(err => {
              console.error('Could not copy text: ', err);
          });
      });
  }

  // Lightbox Modal Logic
  const articleImages = document.querySelectorAll('.article-image');
  const lightboxModal = document.getElementById('lightbox-modal');
  const lightboxImg = document.getElementById('lightbox-img');
  const lightboxClose = document.querySelector('.lightbox-close');

  if (lightboxModal && lightboxImg) {
      articleImages.forEach(img => {
          (img as HTMLImageElement).style.cursor = 'zoom-in';
          img.addEventListener('click', () => {
              (lightboxModal as HTMLElement).style.display = 'flex';
              (lightboxImg as HTMLImageElement).src = (img as HTMLImageElement).src;
              document.body.style.overflow = 'hidden'; // Lock scroll
          });
      });

      const closeLightbox = () => {
          (lightboxModal as HTMLElement).style.display = 'none';
          document.body.style.overflow = ''; // Unlock scroll
      };

      if (lightboxClose) {
          lightboxClose.addEventListener('click', closeLightbox);
      }
      lightboxModal.addEventListener('click', (e) => {
          if (e.target === lightboxModal) {
              closeLightbox();
          }
      });
      document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') {
              closeLightbox();
          }
      });
  }

  // --- Likes implementation ---
  const likeBtn = document.getElementById('like-btn');
  const likeCount = document.getElementById('like-count');
  
  if (likeBtn && likeCount) {
      const postId = likeBtn.getAttribute('data-post-id');
      const likesApiUrl = `/api/likes?post_id=${encodeURIComponent(postId || '')}`;
      const isLocalPreview = ['localhost', '127.0.0.1', '::1'].includes(window.location.hostname);

      const fetchLikesJson = async (url, options) => {
          const res = await fetch(url, options);
          const contentType = res.headers.get('content-type') || '';
          if (!res.ok || !contentType.includes('application/json')) {
              return null;
          }
          return res.json();
      };
      
      // Load initial likes count and status
      if (!isLocalPreview) {
          fetchLikesJson(likesApiUrl)
              .then(data => {
                  if (data && typeof data.likes === 'number') {
                      likeCount.textContent = String(data.likes);
                      if (data.user_liked) {
                          likeBtn.classList.add('liked');
                      }
                  }
              })
              .catch(() => {});
      }
          
      // Click handler
      likeBtn.addEventListener('click', () => {
          if (isLocalPreview) {
              return;
          }
          likeBtn.setAttribute('disabled', 'true');
          fetchLikesJson(likesApiUrl, { method: 'POST' })
              .then(data => {
                  if (data && typeof data.likes === 'number') {
                      likeCount.textContent = String(data.likes);
                      if (data.user_liked) {
                          likeBtn.classList.add('liked');
                      } else {
                          likeBtn.classList.remove('liked');
                      }
                  }
              })
              .catch(() => {})
              .finally(() => {
                  likeBtn.removeAttribute('disabled');
              });
      });
  }

  // --- Giscus comments implementation ---
  const giscusContainer = document.getElementById('giscus-container');
  if (giscusContainer) {
      // Configuration object
      const giscusConfig = {
          repo: "iAlexeyRu/ialexey.ru",
          repoId: "R_kgDOSJwPnQ",
          category: "Announcements",
          categoryId: "DIC_kwDOSJwPnc4C-S2f",
          mapping: "pathname",
          strict: "0",
          reactionsEnabled: "0",
          emitMetadata: "0",
          inputPosition: "bottom",
          lang: "ru",
      };

      const savedTheme = localStorage.getItem('theme') || 'dark';
      const initialGiscusTheme = savedTheme === 'light' ? 'light' : 'dark';

      const script = document.createElement('script');
      script.src = 'https://giscus.app/client.js';
      script.setAttribute('data-repo', giscusConfig.repo);
      script.setAttribute('data-repo-id', giscusConfig.repoId);
      script.setAttribute('data-category', giscusConfig.category);
      script.setAttribute('data-category-id', giscusConfig.categoryId);
      script.setAttribute('data-mapping', giscusConfig.mapping);
      script.setAttribute('data-strict', giscusConfig.strict);
      script.setAttribute('data-reactions-enabled', giscusConfig.reactionsEnabled);
      script.setAttribute('data-emit-metadata', giscusConfig.emitMetadata);
      script.setAttribute('data-input-position', giscusConfig.inputPosition);
      script.setAttribute('data-theme', initialGiscusTheme);
      script.setAttribute('data-lang', giscusConfig.lang);
      script.crossOrigin = 'anonymous';
      script.async = true;
      giscusContainer.appendChild(script);

      // Sync theme switch with Giscus iframe
      const observer = new MutationObserver(() => {
          const newTheme = document.documentElement.getAttribute('data-theme') || 'dark';
          const iframe = document.querySelector('iframe.giscus-frame') as HTMLIFrameElement;
          if (iframe && iframe.contentWindow) {
              iframe.contentWindow.postMessage(
                  { giscus: { setConfig: { theme: newTheme === 'light' ? 'light' : 'dark' } } },
                  'https://giscus.app'
              );
          }
      });
      observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  }
</script>
