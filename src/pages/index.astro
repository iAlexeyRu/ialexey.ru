      transform: translateY(2px);
  }

  /* RESPONSIVE SYSTEM */
  @media (max-width: 900px) {
      .page-layout-grid {
          grid-template-columns: 1fr;
          gap: 1.5rem;
      }
  }
</style>

<script>
  // Search Logic
  document.addEventListener('DOMContentLoaded', () => {
      const filterableItems = document.querySelectorAll('.article-row, .sidebar-item, .featured-item-link');
      const gridContainer = document.querySelector('.page-layout-grid');

      let searchQuery = '';

      function applyFilters() {
          const controlsActive = searchQuery !== '';
          if (gridContainer) {
              if (controlsActive) {
                  gridContainer.classList.add('controls-active');
              } else {
                  gridContainer.classList.remove('controls-active');
              }
          }

          filterableItems.forEach(item => {
              const searchText = item.getAttribute('data-search-text') || '';
              const matchesSearch = searchText.includes(searchQuery);

              if (matchesSearch) {
                  item.classList.remove('hidden-by-search');
              } else {
                  item.classList.add('hidden-by-search');
              }
          });
      }

      const headerSearchInput = document.getElementById('header-search-input');

      function syncSearch(value) {
          if (headerSearchInput && (headerSearchInput as HTMLInputElement).value !== value) {
              (headerSearchInput as HTMLInputElement).value = value;
          }
          searchQuery = value.toLowerCase().trim();
          applyFilters();
      }

      if (headerSearchInput) {
          headerSearchInput.addEventListener('input', (e) => {
              syncSearch((e.target as HTMLInputElement).value);
          });
      }

      // Check URL query parameters on load
      const params = new URLSearchParams(window.location.search);
      const searchParam = params.get('search');
      if (searchParam) {
          syncSearch(searchParam);
          // Clean the URL query param without reload
          const newUrl = window.location.protocol + "//" + window.location.host + window.location.pathname;
          window.history.replaceState({ path: newUrl }, '', newUrl);
      }
  });

  // Articles Expander
  const showMoreBtn = document.getElementById('show-more-btn');
  const articlesList = document.querySelector('.articles-list');
  if (showMoreBtn && articlesList) {
      showMoreBtn.addEventListener('click', () => {
          articlesList.classList.add('articles-list--expanded');
          showMoreBtn.style.display = 'none';
      });
  }

  // Sidebar News Expander
  const sidebarShowMoreBtn = document.getElementById('sidebar-show-more-btn');
  const sidebarList = document.querySelector('.sidebar-list');
  if (sidebarShowMoreBtn && sidebarList) {
      sidebarShowMoreBtn.addEventListener('click', () => {
          sidebarList.classList.add('sidebar-list--expanded');
          const parent = sidebarShowMoreBtn.closest('.sidebar-show-more-wrap');
          if (parent) {
              (parent as HTMLElement).style.display = 'none';
          }
      });
  }
</script>
