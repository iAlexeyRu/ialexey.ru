  .articles-list--expanded .article-row--hidden {
      display: flex !important;
      animation: fadeIn 0.4s ease forwards;
  }

  .sidebar-list--expanded .sidebar-item--hidden {
      display: flex !important;
      animation: fadeIn 0.4s ease forwards;
