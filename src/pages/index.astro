---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../layouts/Layout.astro';

// Configuration
const channelUsername = "iAlexeyRu";
const siteAuthor = "Алексей Гетманец";
const siteTitle = "Алексей Гетманец | Сливы и новости ИИ";
const siteDescription = "Сливы и новости ИИ от Алексея Гетманца: короткая Telegram-лента, RSS и статические страницы постов.";

// Fetch latest completed YouTube video ID at build time (runs every minute on the VPS sync job)
let latestCompletedVideoId = "e-RHZvID8q8"; // High-quality completed stream fallback
try {
  const res = await fetch('https://www.youtube.com/feeds/videos.xml?channel_id=UCMFl8-kqE8n9cyErKFSbPuQ');
  if (res.ok) {
    const xmlText = await res.text();
    const entryRegex = /<entry>([\s\S]*?)<\/entry>/g;
    let match;
    const videos = [];
    
    while ((match = entryRegex.exec(xmlText)) !== null) {
      const entryContent = match[1];
      const idMatch = entryContent.match(/<yt:videoId>([^<]+)<\/yt:videoId>/);
      const titleMatch = entryContent.match(/<title>([^<]+)<\/title>/);
      
      if (idMatch && titleMatch) {
        videos.push({
          id: idMatch[1].trim(),
          title: titleMatch[1].trim()
        });
      }
    }
    
    // Skip any video containing upcoming indicators in their Russian or English title
    const completedVideos = videos.filter(v => {
      const t = v.title.toLowerCase();
      return !t.includes('ожидаем') && !t.includes('ожидани') && !t.includes('waiting') && !t.includes('upcoming');
    });
    
    if (completedVideos.length > 0) {
      latestCompletedVideoId = completedVideos[0].id;
    } else if (videos.length > 0) {
      latestCompletedVideoId = videos[0].id;
    }
  }
} catch (e) {
  console.error('Error fetching or parsing YouTube RSS feed in Astro build:', e);
}

// Load feed items
const dataDir = process.env.DATA_DIR || '/home/deploy/ialexey-feed/data';
const prodFeedJsonPath = path.join(dataDir, 'feed.json');
const localFeedJsonPath = path.resolve('src/data/feed.json');

let parsedData = null;

if (fs.existsSync(prodFeedJsonPath)) {
  try {
    parsedData = JSON.parse(fs.readFileSync(prodFeedJsonPath, 'utf-8'));
  } catch (e) {
    console.error(`Error reading production feed.json:`, e);
  }
}

if (!parsedData && fs.existsSync(localFeedJsonPath)) {
  try {
    parsedData = JSON.parse(fs.readFileSync(localFeedJsonPath, 'utf-8'));
  } catch (e) {
    console.error(`Error reading local feed.json:`, e);
  }
}

// Support both array structure and object wrapping structure
let feedItems = [];
if (parsedData) {
  if (Array.isArray(parsedData)) {
    feedItems = parsedData;
  } else if (parsedData.items && Array.isArray(parsedData.items)) {
    feedItems = parsedData.items;
  }
}

// Sort items by date descending
const sortedItems = feedItems
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

// Format date helpers matching Europe/Moscow timezone format: DD.MM.YYYY HH:MM and HH:MM
function formatDate(value: string) {
  if (!value) return "";
  try {
    const date = new Date(value);
    const formatter = new Intl.DateTimeFormat("ru-RU", {
      timeZone: "Europe/Moscow",
      day: "2-digit",
      month: "2-digit",
      year: "numeric",
      hour: "2-digit",
      minute: "2-digit",
      hour12: false,
    });
    return formatter.format(date).replace(",", "");
  } catch (e) {
    return value;
  }
}

function formatDateRussian(value: string) {
  if (!value) return "";
  try {
    const date = new Date(value);
    const months = [
      "января", "февраля", "марта", "апреля", "мая", "июня",
      "июля", "августа", "сентября", "октября", "ноября", "декабря"
    ];
    const day = date.getDate();
    const month = months[date.getMonth()];
    const formatterTime = new Intl.DateTimeFormat("ru-RU", {
      timeZone: "Europe/Moscow",
      hour: "2-digit",
      minute: "2-digit",
      hour12: false,
    });
    const timeStr = formatterTime.format(date);
    return `${day} ${month}, ${timeStr}`;
  } catch (e) {
    return value;
  }
}

function formatTimeOnly(value: string) {
  if (!value) return "";
  try {
    const date = new Date(value);
    const formatter = new Intl.DateTimeFormat("ru-RU", {
      timeZone: "Europe/Moscow",
      hour: "2-digit",
      minute: "2-digit",
      hour12: false,
    });
    return formatter.format(date);
  } catch (e) {
    return "";
  }
}

// Post path helper
function getPostPath(item: any) {
  const messageId = item.message_id || item.id.split(':').pop();
  return `/posts/${messageId}/`;
}

// Title truncation helpers
function cleanText(text: string) {
  return (text || "").replace(/\n{3,}/g, "\n\n").trim();
}
function compactText(text: string) {
  return cleanText(text).replace(/\s+/g, " ").trim();
}
function truncateText(value: string, limit: number) {
  const text = compactText(value);
  if (text.length <= limit) {
    return text;
  }
  return text.slice(0, Math.max(0, limit - 1)).trimEnd() + "…";
}

// Smart classification of category badges
function getSmartBadge(text: string) {
  const t = (text || "").toLowerCase();
  if (t.includes("слив") || t.includes("утек") || t.includes("секрет") || t.includes("leak") || t.includes("эксклюзив")) {
    return { label: "Сливы", class: "badge--leaks", emoji: "🤫" };
  }
  if (t.includes("gpt") || t.includes("gemini") || t.includes("claude") || t.includes("anthropic") || t.includes("openai") || t.includes("google") || t.includes("llama")) {
    return { label: "ИИ-Модели", class: "badge--ai", emoji: "🧠" };
  }
  if (t.includes("нейросеть") || t.includes("midjourney") || t.includes("sora") || t.includes("генераци") || t.includes("искусствен")) {
    return { label: "Нейросети", class: "badge--neural", emoji: "🎨" };
  }
  return { label: "Новости", class: "badge--news", emoji: "📰" };
}

// Schema.org dynamic markup
const schemaObject = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "https://ialexey.ru/#person",
      "name": siteAuthor,
      "url": "https://ialexey.ru/",
      "image": "https://ialexey.ru/avatar.png",
      "sameAs": [
        `https://t.me/${channelUsername}`,
        "https://x.com/iAlexeyRu"
      ]
    },
    {
      "@type": "WebSite",
      "@id": "https://ialexey.ru/#website",
      "url": "https://ialexey.ru/",
      "name": siteTitle,
      "description": siteDescription,
      "inLanguage": "ru-RU",
      "publisher": { "@id": "https://ialexey.ru/#person" }
    },
    ...(sortedItems.length > 0 ? [{
      "@type": "ItemList",
      "@id": "https://ialexey.ru/#telegram-feed",
      "name": "Последние посты Telegram",
      "itemListElement": sortedItems.map((item, idx) => ({
        "@type": "ListItem",
        "position": idx + 1,
        "url": `https://ialexey.ru${getPostPath(item)}`,
        "name": truncateText(item.text || "", 60)
      }))
    }] : [])
  ]
};

const schema = JSON.stringify(schemaObject);

// 1. "Главное на сегодня" (Top 5 most important/recent posts)
const mainFeaturedItems = sortedItems.slice(0, 5);

// 2. "Статьи" - main posts (we filter posts with images, or render all as dynamic cards in the grid)
const articleItems = sortedItems.filter(item => item.image || item.text.length > 80);

// 3. "Лента всех новостей" (Full list for the sidebar, aligned with mainFeaturedItems height)
const sidebarItems = sortedItems;
---
<Layout title={siteTitle} description={siteDescription} schema={schema}>

  <div class="page-layout-grid">
      
      <!-- LEFT COLUMN: MAIN CONTENT (Main + Stream + Articles) -->
      <div class="main-content-col">
          
          <!-- BLOCK 1: ГЛАВНОЕ НА СЕГОДНЯ (Compact single-line list) -->
          {mainFeaturedItems.length > 0 && (
              <div class="today-featured-card">
                  <h2 class="featured-card-title">Главное на сегодня</h2>
                  <div class="featured-list">
                      {mainFeaturedItems.map((item) => {
                          const timeStr = formatTimeOnly(item.date);
                          const title = truncateText(item.text || "", 115) || `Новость из Telegram ${item.message_id}`;
                          const postUrl = getPostPath(item);
                          return (
                              <a href={postUrl} class="featured-item-link">
                                  <span class="featured-item-time">{timeStr}</span>
                                  <span class="featured-item-text">{title}</span>
                              </a>
                          );
                      })}
                  </div>
              </div>
          )}

          <!-- BLOCK 2: СТРИМ МОЙ (Premium Live Stream Box - Minimalist with YouTube fallback) -->
          <div class="stream-banner" id="stream-block" data-youtube-id={latestCompletedVideoId}>
              <div class="stream-header-row">
                  <div class="stream-title-wrap">
                      <span class="stream-status-dot" id="stream-status-dot"></span>
                      <span class="stream-status-text" id="stream-status-text">Загрузка трансляции...</span>
                  </div>
                  <button id="toggle-stream-btn" class="toggle-stream-btn" aria-label="Свернуть блок">
                      <span class="toggle-text">Свернуть</span>
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="toggle-icon"><path d="m18 15-6-6-6 6"/></svg>
                  </button>
              </div>
              <div class="stream-body-collapsible" id="stream-body-collapsible">
                  <!-- Responsive Video Embed Container -->
                  <div class="stream-embed-container" id="stream-embed-container">
                      <!-- Embed will be dynamically injected by JS below -->
                  </div>
              </div>
          </div>

          <!-- BLOCK 3: СТАТЬИ (Horizontal Row list - Championat style) -->
          <section class="articles-section">
              <h2 class="section-title">Статьи</h2>
              {articleItems.length === 0 ? (
                  <div class="telegram-feed__empty" style="padding: 3rem; text-align: center;">Постов пока нет. Новые посты появятся здесь автоматически!</div>
              ) : (
                  <div class="articles-list">
                      {articleItems.map((item, index) => {
                          const badge = getSmartBadge(item.text);
                          const dateStr = formatDateRussian(item.date);
                          const title = truncateText(item.text || "", 86) || `Пост Telegram ${item.message_id}`;
                          const desc = truncateText(item.text || "", 180);
                          const postUrl = getPostPath(item);
                          const isHidden = index >= 5;
                          return (
                              <a href={postUrl} class={`article-row ${isHidden ? 'article-row--hidden' : ''}`}>
                                  <div class="article-row__img-container">
                                      {item.image ? (
                                          <img 
                                              src={`/${item.image}`} 
                                              class="article-row__img" 
                                              alt="Обложка статьи" 
                                              loading="lazy"
                                          />
                                      ) : (
                                          <div class="article-row__placeholder-img">
                                              <span class="placeholder-emoji">{badge.emoji}</span>
                                          </div>
                                      )}
                                      <span class={`article-row__badge-overlay badge ${badge.class}`}>{badge.label}</span>
                                  </div>
                                  <div class="article-row__content">
                                      <h3 class="article-row__title">{title}</h3>
                                      <p class="article-row__desc">{desc}</p>
                                      <div class="article-row__meta-row">
                                          <span class="article-row__date">{dateStr}</span>
                                      </div>
                                  </div>
                              </a>
                          );
                      })}
                  </div>
              )}

              {articleItems.length > 5 && (
                  <div class="articles-show-more-wrap">
                      <button id="show-more-btn" class="show-more-btn">
                          <span>Смотреть все</span>
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="show-more-btn__icon"><path d="m6 9 6 6 6-6"/></svg>
                      </button>
                  </div>
              )}
          </section>

      </div>

      <!-- RIGHT COLUMN: SIDEBAR LENTA (Championat.com style) -->
      {sidebarItems.length > 0 && (
          <aside class="sidebar-col">
              <div class="sidebar-header">
                  <h2 class="sidebar-main-title">Лента всех новостей</h2>
              </div>
              
              <div class="sidebar-list">
                  {sidebarItems.map((item, index) => {
                      const timeStr = formatTimeOnly(item.date);
                      const title = truncateText(item.text || "", 120) || `Обновление ленты ${item.message_id}`;
                      const postUrl = getPostPath(item);
                      const isHidden = index >= 10;
                      return (
                          <a href={postUrl} class={`sidebar-item ${isHidden ? 'sidebar-item--hidden' : ''}`}>
                              <span class="sidebar-item-time">{timeStr}</span>
                              <span class="sidebar-item-text">{title}</span>
                          </a>
                      );
                  })}
              </div>

              {sidebarItems.length > 10 && (
                  <div class="sidebar-show-more-wrap">
                      <button id="sidebar-show-more-btn" class="sidebar-show-more-btn">
                          <span>Показать все</span>
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="sidebar-show-more-btn__icon"><path d="m6 9 6 6 6-6"/></svg>
                      </button>
                  </div>
              )}
          </aside>
      )}

  </div>

</Layout>

<style>
  /* MAIN PAGE GRID SYSTEM */
  .page-layout-grid {
      display: grid;
      grid-template-columns: 1.8fr 1fr;
      gap: 2.5rem;
  }

  .main-content-col {
      display: flex;
      flex-direction: column;
      gap: 2.5rem;
      min-width: 0; /* Prevent flex/nowrap children from expanding column */
  }

  /* 1. ГЛАВНОЕ НА СЕГОДНЯ BOX - COMPACT */
  .today-featured-card {
      background-color: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 0.9rem 1.15rem;
  }

  .featured-card-title {
      font-size: 1.15rem;
      margin: 0 0 0.85rem;
      font-family: var(--font-heading);
      font-weight: 700;
      color: var(--text-header);
      text-transform: uppercase;
      letter-spacing: 0.02em;
      border-left: 3px solid var(--accent);
      padding-left: 0.6rem;
  }

  .featured-list {
      display: flex;
      flex-direction: column;
  }

  .featured-item-link {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.4rem 0;
      border-bottom: 1px solid var(--border-soft);
      transition: all 0.2s ease;
  }

  .featured-item-link:last-child {
      border-bottom: none;
      padding-bottom: 0;
  }

  .featured-item-link:first-child {
      padding-top: 0;
  }

  .featured-item-time {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      color: var(--text-muted);
      flex: 0 0 42px;
      font-weight: 400;
  }

  .featured-item-text {
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--text-main);
      line-height: 1.4;
      white-space: nowrap; /* Strictly single line */
      text-overflow: ellipsis; /* Appends ... */
      overflow: hidden; /* Hides overflow */
      flex-grow: 1;
  }

  .featured-item-link:hover .featured-item-text {
      color: var(--accent);
  }

  .featured-item-link:hover {
      transform: translateX(4px);
  }

  /* 2. PREMIUM STREAM BANNER WITH YOUTUBE FALLBACK */
  .stream-banner {
      background: linear-gradient(135deg, rgba(25, 20, 36, 0.6) 0%, rgba(13, 17, 26, 0.8) 100%);
      border: 1px solid rgba(145, 70, 255, 0.2);
      border-radius: 16px;
      padding: 0.9rem 1.15rem;
      position: relative;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(145, 70, 255, 0.05);
      transition: all 0.3s ease;
  }

  .stream-header-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 0.75rem;
      transition: margin 0.3s ease;
  }

  .stream-banner--collapsed .stream-header-row {
      margin-bottom: 0;
  }

  .stream-title-wrap {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
  }

  .stream-status-dot {
      width: 8px;
      height: 8px;
      background-color: #6c7482;
      border-radius: 50%;
      transition: all 0.3s ease;
  }

  .stream-status-dot.live {
      background-color: var(--accent);
      box-shadow: 0 0 10px var(--accent);
      animation: pulse 1.8s infinite;
  }

  .stream-status-dot.offline {
      background-color: #ff0055; /* YouTube Red Vibe */
      box-shadow: 0 0 8px rgba(255, 0, 85, 0.4);
  }

  .stream-status-text {
      font-family: var(--font-heading);
      font-size: 0.82rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--text-header);
  }

  .toggle-stream-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: transparent;
      border: none;
      color: #6c7482;
      font-family: var(--font-mono);
      font-size: 0.72rem;
      cursor: pointer;
      padding: 4px 8px;
      border-radius: 4px;
      transition: all 0.2s ease;
  }

  .toggle-stream-btn:hover {
      color: var(--text-header);
      background-color: var(--border-soft);
  }

  .toggle-icon {
      width: 14px;
      height: 14px;
      transition: transform 0.3s ease;
  }

  .stream-banner--collapsed .toggle-icon {
      transform: rotate(180deg);
  }

  .stream-body-collapsible {
      max-height: 800px;
      overflow: hidden;
      transition: max-height 0.4s cubic-bezier(0, 1, 0, 1);
  }

  .stream-banner--collapsed .stream-body-collapsible {
      max-height: 0;
  }

  .stream-embed-container {
      aspect-ratio: 16 / 9;
      width: 100%;
      border-radius: 10px;
      overflow: hidden;
      border: 1px solid rgba(145, 70, 255, 0.25);
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.5);
  }

  .stream-banner.live-border {
      border-color: rgba(145, 70, 255, 0.3);
  }

  .stream-banner.offline-border {
      border-color: rgba(255, 0, 85, 0.2);
  }

  .stream-banner::before {
      content: "";
      position: absolute;
      top: -50%;
      right: -20%;
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(145, 70, 255, 0.15) 0%, transparent 70%);
      pointer-events: none;
  }

  .stream-header-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1rem;
      flex-wrap: wrap;
      gap: 0.5rem;
  }

  .stream-live-tag {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background-color: rgba(145, 70, 255, 0.1);
      border: 1px solid rgba(145, 70, 255, 0.3);
      padding: 3px 10px;
      border-radius: 20px;
      font-family: var(--font-mono);
      font-size: 0.65rem;
      font-weight: 700;
      color: #b380ff;
      text-transform: uppercase;
  }

  .stream-live-dot {
      width: 6px;
      height: 6px;
      background-color: #9146ff;
      border-radius: 50%;
      box-shadow: 0 0 8px #9146ff;
  }

  .stream-subtitle-mono {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      color: #6c7482;
      letter-spacing: 1px;
  }

  .stream-title {
      font-family: var(--font-heading);
      font-size: 1.4rem;
      color: var(--text-header);
      margin: 0 0 0.5rem;
  }

  .stream-text {
      font-size: 0.95rem;
      line-height: 1.5;
      color: var(--text-main);
      margin: 0 0 1.25rem;
      max-width: 650px;
  }

  .stream-buttons {
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
  }

  .stream-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      font-family: var(--font-mono);
      font-size: 0.82rem;
      font-weight: bold;
      padding: 0.65rem 1.25rem;
      border-radius: 6px;
      transition: all 0.2s;
  }

  .stream-btn--youtube {
      background-color: #FF0000;
      color: #ffffff;
      box-shadow: 0 4px 12px rgba(255, 0, 0, 0.2);
  }

  .stream-btn--youtube:hover {
      background-color: #cc0000;
      transform: translateY(-2px);
      color: #ffffff;
  }

  .stream-btn--twitch {
      background-color: #9146FF;
      color: #ffffff;
      box-shadow: 0 4px 12px rgba(145, 70, 255, 0.2);
  }

  .stream-btn--twitch:hover {
      background-color: #772ce8;
      transform: translateY(-2px);
      color: #ffffff;
  }

  .stream-btn-icon {
      width: 16px;
      height: 16px;
  }

  /* Managed inside stream-banner styles above */

  /* 3. ARTICLES SECTION TITLE & GRID */
  .section-title {
      font-size: 1.5rem;
      margin: 0 0 1.5rem;
      font-family: var(--font-heading);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.02em;
      border-left: 3px solid var(--accent);
      padding-left: 0.75rem;
      color: var(--text-header);
  }

  .articles-list {
      display: flex;
      flex-direction: column;
      gap: 1.75rem;
  }

  .article-row {
      display: flex;
      gap: 1.5rem;
      padding-bottom: 1.75rem;
      border-bottom: 1px solid var(--border-soft);
      transition: all 0.25s ease;
  }

  .article-row:last-child {
      border-bottom: none;
      padding-bottom: 0;
  }

  .article-row__img-container {
      position: relative;
      flex: 0 0 240px;
      aspect-ratio: 16 / 9;
      border-radius: 8px;
      overflow: hidden;
      background-color: #000;
      border: 1px solid var(--border);
  }

  .article-row__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
  }

  .article-row:hover .article-row__img {
      transform: scale(1.05);
  }

  .article-row__placeholder-img {
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, var(--card-bg) 0%, var(--bg-color) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
  }

  .placeholder-emoji {
      font-size: 2.2rem;
      opacity: 0.8;
  }

  .article-row__badge-overlay {
      position: absolute;
      top: 8px;
      left: 8px;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.4);
      z-index: 10;
  }

  .article-row__content {
      display: flex;
      flex-direction: column;
      flex-grow: 1;
      justify-content: center;
  }

  .article-row__title {
      font-family: var(--font-heading);
      font-size: 1.25rem;
      font-weight: 700;
      line-height: 1.35;
      color: var(--text-header);
      margin: 0 0 0.5rem;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      transition: color 0.2s;
  }

  .article-row:hover .article-row__title {
      color: var(--accent);
  }

  .article-row__desc {
      font-size: 0.9rem;
      line-height: 1.5;
      color: var(--text-secondary);
      margin: 0 0 0.75rem;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
  }

  .article-row__meta-row {
      display: flex;
      align-items: center;
      gap: 0.75rem;
  }

  .article-row__date {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      color: var(--text-muted);
  }

  @media (max-width: 600px) {
      .article-row {
          flex-direction: column;
          gap: 1rem;
      }
      .article-row__img-container {
          flex: 0 0 auto;
          width: 100%;
      }
  }

  /* 4. CHAMPIONAT SIDEBAR - ALIGNED TO TOP GRID */
  .sidebar-col {
      display: flex;
      flex-direction: column;
      background-color: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 0.9rem 1.15rem;
      min-width: 0; /* Allow clean resizing */
      height: fit-content;
  }

  .sidebar-header {
      padding-bottom: 0.85rem;
      border-bottom: 2px solid var(--accent);
      margin-bottom: 0.75rem;
  }

  .sidebar-main-title {
      font-size: 1.1rem;
      margin: 0;
      font-family: var(--font-heading);
      font-weight: 700;
      color: var(--text-header);
      text-transform: uppercase;
      letter-spacing: 0.02em;
  }

  .sidebar-list {
      display: flex;
      flex-direction: column;
  }

  .sidebar-item {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      padding: 14px 0;
      border-bottom: 1px dashed var(--border-dashed);
      transition: all 0.2s ease;
  }

  .sidebar-item:last-child {
      border-bottom: none;
  }

  .sidebar-item-time {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      color: var(--text-muted);
      flex: 0 0 42px;
      font-weight: 400;
      margin-top: 0.15rem; /* Align perfectly with first line of text */
  }

  .sidebar-item-text {
      font-size: 0.9rem;
      line-height: 1.45;
      color: var(--text-main);
      font-weight: 500;
      flex-grow: 1;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
  }

  .sidebar-item:hover .sidebar-item-text {
      color: var(--accent);
  }

  .sidebar-item:hover {
      transform: translateX(4px);
  }

  .sidebar-item--hidden {
      display: none !important;
  }

  .sidebar-list--expanded .sidebar-item--hidden {
      display: flex !important;
      animation: fadeIn 0.4s ease forwards;
  }

  .sidebar-show-more-wrap {
      display: flex;
      justify-content: center;
      margin-top: 1.25rem;
      padding-top: 0.85rem;
      border-top: 1px solid var(--border-soft);
  }

  .sidebar-show-more-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background-color: transparent;
      border: 1px solid var(--border);
      color: var(--text-header);
      padding: 0.5rem 1.25rem;
      border-radius: 6px;
      font-family: var(--font-heading);
      font-size: 0.78rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      cursor: pointer;
      transition: all 0.25s ease;
  }

  .sidebar-show-more-btn:hover {
      background-color: var(--accent-glow);
      border-color: var(--accent);
      color: var(--accent);
      box-shadow: 0 4px 12px var(--accent-glow);
  }

  .sidebar-show-more-btn__icon {
      width: 14px;
      height: 14px;
      transition: transform 0.25s ease;
  }

  .sidebar-show-more-btn:hover .sidebar-show-more-btn__icon {
      transform: translateY(2px);
  }

  .article-row--hidden {
      display: none !important;
  }

  .articles-list--expanded .article-row--hidden {
      display: flex !important;
      animation: fadeIn 0.4s ease forwards;
  }

  @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
  }

  .articles-show-more-wrap {
      display: flex;
      justify-content: center;
      margin-top: 2rem;
  }

  .show-more-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background-color: transparent;
      border: 1px solid var(--border);
      color: var(--text-header);
      padding: 0.75rem 2rem;
      border-radius: 8px;
      font-family: var(--font-heading);
      font-size: 0.85rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      cursor: pointer;
      transition: all 0.25s ease;
  }

  .show-more-btn:hover {
      background-color: var(--accent-glow);
      border-color: var(--accent);
      color: var(--accent);
      box-shadow: 0 4px 15px var(--accent-glow);
  }

  .show-more-btn__icon {
      width: 16px;
      height: 16px;
      transition: transform 0.25s ease;
  }

  .show-more-btn:hover .show-more-btn__icon {
      transform: translateY(2px);
  }

  /* RESPONSIVE SYSTEM */
  @media (max-width: 900px) {
      .page-layout-grid {
          grid-template-columns: 1fr;
          gap: 1.5rem;
      }
  }
</style>

<script>
  // Articles Expander
  const showMoreBtn = document.getElementById('show-more-btn');
  const articlesList = document.querySelector('.articles-list');
  if (showMoreBtn && articlesList) {
      showMoreBtn.addEventListener('click', () => {
          articlesList.classList.add('articles-list--expanded');
          showMoreBtn.style.display = 'none';
      });
  }

  // Sidebar News Expander
  const sidebarShowMoreBtn = document.getElementById('sidebar-show-more-btn');
  const sidebarList = document.querySelector('.sidebar-list');
  if (sidebarShowMoreBtn && sidebarList) {
      sidebarShowMoreBtn.addEventListener('click', () => {
          sidebarList.classList.add('sidebar-list--expanded');
          sidebarShowMoreBtn.closest('.sidebar-show-more-wrap').style.display = 'none';
      });
  }

  // Twitch/YouTube Live Swapper and Collapse Toggle
  const streamBlock = document.getElementById('stream-block');
  const statusDot = document.getElementById('stream-status-dot');
  const statusText = document.getElementById('stream-status-text');
  const embedContainer = document.getElementById('stream-embed-container');
  const toggleBtn = document.getElementById('toggle-stream-btn');
  const toggleText = toggleBtn?.querySelector('.toggle-text');
  const youtubeId = streamBlock?.getAttribute('data-youtube-id') || 'e-RHZvID8q8';

  if (streamBlock && embedContainer) {
      // 1. Fetch live status from Decapi.me
      fetch('https://decapi.me/twitch/uptime/ialexeyru')
          .then(res => res.text())
          .then(text => {
              const isLive = !text.toLowerCase().includes('offline');
              if (isLive) {
                  statusDot?.classList.add('live');
                  if (statusText) statusText.textContent = 'LIVE: Трансляция на Twitch';
                  streamBlock.classList.add('live-border');
                  embedContainer.innerHTML = `
                      <iframe
                          src="https://player.twitch.tv/?channel=ialexeyru&parent=ialexey.ru&parent=localhost&parent=127.0.0.1&autoplay=false"
                          style="border: 0; width: 100%; height: 100%;"
                          allowfullscreen="true">
                      </iframe>
                  `;
              } else {
                  statusDot?.classList.add('offline');
                  if (statusText) statusText.textContent = 'Последнее видео с YouTube';
                  streamBlock.classList.add('offline-border');
                  embedContainer.innerHTML = `
                      <iframe
                          src="https://www.youtube.com/embed/${youtubeId}"
                          style="border: 0; width: 100%; height: 100%;"
                          allowfullscreen="true"
                          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture">
                      </iframe>
                  `;
              }
          })
          .catch(() => {
              // Fallback to YouTube on error
              statusDot?.classList.add('offline');
              if (statusText) statusText.textContent = 'Последнее видео с YouTube';
              streamBlock.classList.add('offline-border');
              embedContainer.innerHTML = `
                  <iframe
                      src="https://www.youtube.com/embed/${youtubeId}"
                      style="border: 0; width: 100%; height: 100%;"
                      allowfullscreen="true"
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture">
                  </iframe>
              `;
          });

      // 2. Collapse Toggle
      if (toggleBtn && toggleText) {
          toggleBtn.addEventListener('click', () => {
              const isCollapsed = streamBlock.classList.toggle('stream-banner--collapsed');
              toggleText.textContent = isCollapsed ? 'Развернуть' : 'Свернуть';
          });
      }
  }
</script>
