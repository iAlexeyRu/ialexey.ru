                    <span>Перейти к новостям</span>
                </button>
            </div>

            <!-- Mini Telegram Feed on Stream Page -->
            {mainFeaturedItems.length > 0 && (
                <section class="live-stream-news" aria-labelledby="live-news-title">
                    <h3 class="live-news-title" id="live-news-title">Последние новости в Telegram</h3>
                    <div class="live-news-grid">
                        {mainFeaturedItems.slice(0, 3).map((item) => {
                            const timeStr = formatTimeOnly(item.date);
                            const textContent = (item.text || "").trim();
                            const titleRaw = item.title ? item.title : getFirstSentence(textContent);
                            const title = truncateText(removeLeadingEmoji(titleRaw), 110) || `Новость из Telegram ${item.message_id}`;
                            const postUrl = getPostPath(item);
                            const badge = getSmartBadge(item.text || "");
                            
                            return (
                                <a href={postUrl} class="live-news-card">
                                    <div class="live-news-card-meta">
                                        <span class={`badge ${badge.class}`}>{badge.label}</span>
                                        <span class="live-news-time">{timeStr}</span>
                                    </div>
                                    <p class="live-news-card-text">{title}</p>
                                    {item.views > 0 && (
                                        <span class="live-news-views">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="views-icon"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                                            {formatViewsCount(item.views)}
                                        </span>
                                    )}
                                </a>
                            );
                        })}
                    </div>
                </section>
            )}
        </div>
    </div>

</Layout>

