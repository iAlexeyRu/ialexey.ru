        flex-shrink: 0;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, rgba(240, 68, 101, 0.08) 0%, rgba(240, 68, 101, 0.15) 100%);
        border: 1px solid rgba(240, 68, 101, 0.25);
        border-radius: 10px;
    }

    .plus-card__diamond {
        width: 24px;
        height: 24px;
        animation: plus-float 3s ease-in-out infinite;
    }

    @keyframes plus-float {
        0% { transform: translateY(0px) rotate(0deg); }
        50% { transform: translateY(-4px) rotate(5deg); }
        100% { transform: translateY(0px) rotate(0deg); }
    }

    .plus-card__info {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .plus-card__title {
        font-family: var(--font-heading);
        font-size: 1.05rem;
        font-weight: 800;
        margin: 0;
        background: linear-gradient(135deg, #FF5E7E 0%, #F04465 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .plus-card__description {
        font-size: 0.82rem;
        line-height: 1.45;
        color: var(--text-secondary);
        margin: 0;
    }

    .plus-card__footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-top: 0.25rem;
    }

    .plus-card__price {
        font-family: var(--font-heading);
        font-size: 1.15rem;
        font-weight: 800;
        color: var(--text-header);
    }

    .plus-card__period {
        font-size: 0.75rem;
        font-weight: 400;
        color: var(--text-muted);
    }

    .plus-card__btn {
        background: linear-gradient(135deg, #FF5E7E 0%, #F04465 100%);
        border: none;
        color: #fff;
        font-family: var(--font-heading);
        font-size: 0.82rem;
        font-weight: 700;
        padding: 0.5rem 1rem;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.25s ease;
        box-shadow: 0 4px 15px rgba(240, 68, 101, 0.2);
    }

    .plus-card__btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(240, 68, 101, 0.3);
        filter: brightness(1.05);
    }

    .plus-card__btn:active {
        transform: translateY(0);
    }
</style>

<script>
  // Homepage filtering: mirrors the global search input into visible sections.
  document.addEventListener('DOMContentLoaded', () => {
      const filterableItems = Array.from(document.querySelectorAll('.sidebar-item, .featured-item-link, .article-card-uniform'));
      const gridContainer = document.querySelector('.page-layout-grid');
      const emptyState = document.getElementById('filter-empty-state');
      const headerSearchInput = document.getElementById('header-search-input');

      const regularLayout = document.getElementById('regular-homepage-layout');
      const liveLayout = document.getElementById('live-stream-layout');
      const playerIframe = document.getElementById('twitch-live-player') as HTMLIFrameElement;
      const chatIframe = document.getElementById('twitch-live-chat') as HTMLIFrameElement;
      const backToSiteBtn = document.getElementById('back-to-site-btn');
      const toggleChatBtn = document.getElementById('toggle-chat-btn');
      const liveChatCol = document.getElementById('live-chat-col');

      const params = new URLSearchParams(window.location.search);
      const testLive = params.get('test_live') === 'true' || params.get('live') === '1';
      let isLive = false;
      let userIgnored = sessionStorage.getItem('ignoreLiveStream') === 'true';

      function setupTwitchEmbeds() {
          if (playerIframe && !playerIframe.src) {
              playerIframe.src = "https://player.twitch.tv/?channel=ialexeyru&parent=ialexey.ru&parent=localhost&parent=127.0.0.1&autoplay=true";
          }
          if (chatIframe && !chatIframe.src) {
              chatIframe.src = "https://www.twitch.tv/embed/ialexeyru/chat?parent=ialexey.ru&parent=localhost&parent=127.0.0.1&darkpopout";
          }
      }

      function stopTwitchEmbeds() {
          if (playerIframe) playerIframe.src = "";
          if (chatIframe) chatIframe.src = "";
      }

      function showLiveStream() {
          if (regularLayout && liveLayout) {
              regularLayout.style.display = 'none';
              liveLayout.style.display = 'block';
              setupTwitchEmbeds();
          }
      }

      function hideLiveStream() {
          if (regularLayout && liveLayout) {
              liveLayout.style.display = 'none';
              regularLayout.style.display = 'block';
              stopTwitchEmbeds();
          }
      }

      let searchQuery = '';

      function applyFilters() {
          const controlsActive = searchQuery !== '';
          let visibleCount = 0;

          // If searching, always hide live stream layout to show search results
          if (controlsActive) {
              hideLiveStream();
          } else if (isLive && !userIgnored) {
              showLiveStream();
          }

          if (gridContainer) {
              if (controlsActive) {
                  gridContainer.classList.add('controls-active');
              } else {
                  gridContainer.classList.remove('controls-active');
              }
          }

          filterableItems.forEach(item => {
              const searchText = item.getAttribute('data-search-text') || '';
              const matchesSearch = searchText.includes(searchQuery);

              if (matchesSearch) {
                  item.classList.remove('hidden-by-search');
              } else {
                  item.classList.add('hidden-by-search');
              }

              if (matchesSearch) {
                  visibleCount += 1;
              }
          });

          if (emptyState) {
              emptyState.classList.toggle('is-visible', controlsActive && visibleCount === 0);
          }
      }

      function syncSearch(value) {
          if (headerSearchInput && headerSearchInput.value !== value) {
              headerSearchInput.value = value;
          }
          searchQuery = value.toLowerCase().trim();
          applyFilters();
      }

      if (headerSearchInput) {
          headerSearchInput.addEventListener('input', (e) => {
              syncSearch((e.target as HTMLInputElement).value);
          });
      }

      window.addEventListener('site-search-query', (e: any) => {
          syncSearch(e.detail?.query || '');
      });

      const searchParam = params.get('search');
      if (searchParam) {
          syncSearch(searchParam);
      }

      // Live Stream Actions
      if (backToSiteBtn) {
          backToSiteBtn.addEventListener('click', () => {
              sessionStorage.setItem('ignoreLiveStream', 'true');
              userIgnored = true;
              hideLiveStream();
          });
      }

      let chatVisible = true;
      if (toggleChatBtn && liveChatCol) {
          toggleChatBtn.addEventListener('click', () => {
              chatVisible = !chatVisible;
              if (chatVisible) {
                  liveChatCol.style.display = 'block';
                  toggleChatBtn.querySelector('span')!.textContent = 'Скрыть чат';
              } else {
                  liveChatCol.style.display = 'none';
                  toggleChatBtn.querySelector('span')!.textContent = 'Показать чат';
              }
          });
      }

      // Check stream status
      if (testLive) {
          isLive = true;
          showLiveStream();
      } else if (!userIgnored) {
          fetch('https://decapi.me/twitch/uptime/ialexeyru')
              .then(res => res.text())
              .then(text => {
                  isLive = !text.toLowerCase().includes('offline');
                  if (isLive) {
                      showLiveStream();
                  }
              })
              .catch(err => console.error('Error checking Twitch live status:', err));
      }

      // Check Plus Card status
      const plusCard = document.getElementById('plus-card');
      const plusCardClose = document.getElementById('plus-card-close');
      const plusCardBtn = document.getElementById('plus-card-subscribe-btn');

      if (plusCard && localStorage.getItem('hidePlusCard') !== 'true') {
          plusCard.style.display = 'flex';
      }

      if (plusCardClose && plusCard) {
          plusCardClose.addEventListener('click', () => {
              plusCard.style.opacity = '0';
              plusCard.style.transform = 'translateY(10px)';
              plusCard.style.transition = 'all 0.3s ease';
              setTimeout(() => {
                  plusCard.style.display = 'none';
                  localStorage.setItem('hidePlusCard', 'true');
              }, 300);
          });
      }

      if (plusCardBtn) {
          plusCardBtn.addEventListener('click', () => {
              const originalText = plusCardBtn.textContent;
              plusCardBtn.textContent = 'В разработке ❤️';
              plusCardBtn.style.background = 'linear-gradient(135deg, #3fb950 0%, #00e676 100%)';
              plusCardBtn.style.boxShadow = '0 4px 15px rgba(0, 230, 118, 0.25)';
              setTimeout(() => {
                  plusCardBtn.textContent = originalText;
                  plusCardBtn.style.background = '';
                  plusCardBtn.style.boxShadow = '';
              }, 3000);
          });
      }
  });

  // Sidebar News Expander
  const sidebarShowMoreBtn = document.getElementById('sidebar-show-more-btn');
  const sidebarList = document.querySelector('.sidebar-list');
  if (sidebarShowMoreBtn && sidebarList) {
      sidebarShowMoreBtn.addEventListener('click', () => {
          sidebarList.classList.add('sidebar-list--expanded');
          const parent = sidebarShowMoreBtn.closest('.sidebar-show-more-wrap');
          if (parent) {
              (parent as HTMLElement).style.display = 'none';
          }
      });
  }
</script>
